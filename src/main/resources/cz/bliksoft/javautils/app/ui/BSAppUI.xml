	<file name="core">
		<file name="key-bindings">
			<file name="multivalue-editors">
				<file name="add">
					<attribute name="keys" value="Insert" />
				</file>
				<file name="preview">
					<attribute name="keys" value="F3" />
				</file>
				<file name="remove">
					<attribute name="keys" value="Delete" />
				</file>
				<file name="move-up">
					<attribute name="keys" value="Alt+Up" />
				</file>
				<file name="move-down">
					<attribute name="keys" value="Alt+Down" />
				</file>
			</file>
		</file>
		<file name="actions" id="registered-actions" />

		<file name="iconspec">
			<!-- Named size variables -->
			<attribute name="toolbar-size" value="24" />
			<attribute name="toolbar-small" value="16" />
			<attribute name="toolbar-large" value="32" />
			<attribute name="label-icon-size" value="16" />
			<attribute name="tab-icon-size" value="16" />
			<attribute name="menu-icon-size" value="16" />
			<attribute name="main-title-icon-size" value="32" />
			<attribute name="window-title-icon-size" value="16" />
			<attribute name="edit-button-size" value="12" />
			<attribute name="button-size" value="16" />

			<attribute name="overlay-size" value="${button-size}/2" />
			<attribute name="toolbar-overlay-size"
				value="${toolbar-size}/5*3" />

			<!-- Colour variables (theme-agnostic defaults, finetuned later) -->
			<attribute name="fill" value="" />
			<attribute name="stroke-add" value="2b8a3e" />
			<attribute name="stroke-remove" value="c0392b" />
			<attribute name="stroke-delete" value="c0392b" />
			<attribute name="stroke-edit" value="1971c2" />
			<attribute name="stroke-info" value="1971c2" />
			<attribute name="stroke-warning" value="e67700" />
			<attribute name="stroke-error" value="c0392b" />
			<attribute name="stroke-button" value="c0c0c0" />
			<attribute name="window-title-icon-stroke" value="c0c0c0" />

			<!-- Framework action iconspecs. iconspec = toolbar (primary) menu-iconspec 
				= menu variant; if absent, ActionBinder falls back to iconspec -->
			<file name="action">
				<file name="add">
					<attribute name="iconspec">svg/plus.svg|${toolbar-size}|||${stroke-add}
					</attribute>
					<attribute name="menu-iconspec">svg/plus.svg|${menu-icon-size}|||${stroke-add}
					</attribute>
				</file>
				<file name="add-select">
					<attribute name="iconspec">svg/plus.svg|${toolbar-size}|||${stroke-add}
					</attribute>
					<attribute name="menu-iconspec">svg/plus.svg|${menu-icon-size}|||${stroke-add}
					</attribute>
				</file>
				<file name="delete">
					<attribute name="iconspec">svg/minus.svg|${toolbar-size}|||${stroke-delete}
					</attribute>
					<attribute name="menu-iconspec">svg/minus.svg|${menu-icon-size}|||${stroke-delete}
					</attribute>
				</file>
				<file name="remove">
					<attribute name="iconspec">svg/minus.svg|${toolbar-size}|||${stroke-remove}
					</attribute>
					<attribute name="menu-iconspec">svg/minus.svg|${menu-icon-size}|||${stroke-remove}
					</attribute>
				</file>
				<file name="context-help">
					<attribute name="iconspec">svg/help.svg|${toolbar-size}</attribute>
					<attribute name="menu-iconspec">svg/help.svg|${menu-icon-size}
					</attribute>
				</file>
				<file name="administration">
					<attribute name="iconspec">svg/settings.svg|${toolbar-size}
					</attribute>
					<attribute name="menu-iconspec">svg/settings.svg|${menu-icon-size}
					</attribute>
				</file>
				<file name="local-settings">
					<attribute name="iconspec">svg/adjustments.svg|${toolbar-size}|||green
					</attribute>
					<attribute name="menu-iconspec">svg/adjustments.svg|${menu-icon-size}||||green
					</attribute>
				</file>
				<file name="login">
					<attribute name="iconspec">svg/login.svg|${toolbar-size}</attribute>
					<attribute name="menu-iconspec">svg/login.svg|${menu-icon-size}
					</attribute>
				</file>
				<file name="logout">
					<attribute name="iconspec">svg/logout.svg|${toolbar-size}
					</attribute>
					<attribute name="menu-iconspec">svg/logout.svg|${menu-icon-size}
					</attribute>
				</file>
				<file name="save">
					<attribute name="iconspec">svg/save.svg|${toolbar-size}||||red
					</attribute>
					<attribute name="menu-iconspec">svg/save.svg|${menu-icon-size}||||red
					</attribute>
				</file>
				<file name="save-all">
					<attribute name="iconspec">*EMPTY|24#svg/save.svg|16||||00ff00#*ANCHOR|TL#*+#svg/save.svg|16||||ff0000#*ANCHOR|BR#*+
					</attribute>
				</file>
				<file name="close">
					<attribute name="iconspec">*ANCHOR|C#svg/shapes/outline/square.svg|24#svg/shapes/outline/x.svg|24|||${stroke-remove}#*+
					</attribute>
				</file>
				<file name="close-all">
					<attribute name="iconspec">svg/shapes/outline/square.svg|20#*PUSH#*ANCHOR|C|4|4#*+|E#svg/shapes/outline/x.svg|16|||${stroke-remove}#*ANCHOR|C|0|0#*+
					</attribute>
				</file>
				<file name="preview">
					<attribute name="iconspec">svg/search.svg|${toolbar-size}
					</attribute>
					<attribute name="menu-iconspec">svg/search.svg|${menu-icon-size}
					</attribute>
				</file>
				<file name="print">
					<attribute name="iconspec">svg/printer.svg|${toolbar-size}
					</attribute>
					<attribute name="menu-iconspec">svg/printer.svg|${menu-icon-size}
					</attribute>
				</file>
				<file name="refresh">
					<attribute name="iconspec">svg/refresh.svg|${toolbar-size}
					</attribute>
					<attribute name="menu-iconspec">svg/refresh.svg|${menu-icon-size}
					</attribute>
				</file>
				<file name="reload">
					<attribute name="iconspec">svg/refresh-dot.svg|${toolbar-size}
					</attribute>
					<attribute name="menu-iconspec">svg/refresh-dot.svg|${menu-icon-size}
					</attribute>
				</file>
			</file>

			<file name="editor">
				<file name="add">
					<attribute name="iconspec">svg/plus.svg|${edit-button-size}|||${stroke-add}
					</attribute>
				</file>
				<file name="remove">
					<attribute name="iconspec">svg/minus.svg|${edit-button-size}|||${stroke-remove}
					</attribute>
				</file>
				<file name="edit">
					<attribute name="iconspec">svg/edit.svg|${edit-button-size}|||${stroke-edit}
					</attribute>
				</file>
				<file name="preview">
					<attribute name="iconspec">svg/info-square.svg|${edit-button-size}|||${stroke-info}
					</attribute>
				</file>
				<file name="move-up">
					<attribute name="iconspec">svg/arrows/arrow-up.svg|${edit-button-size}|||${stroke-button}
					</attribute>
				</file>
				<file name="move-down">
					<attribute name="iconspec">svg/arrows/arrow-down.svg|${edit-button-size}|||${stroke-button}
					</attribute>
				</file>
			</file>

			<!-- Codebook selector -->
			<file name="codebook">
				<file name="open">
					<attribute name="iconspec">svg/list.svg|${button-size}|||${stroke-button}
					</attribute>
				</file>
				<file name="dialog">
					<file name="list">
						<attribute name="iconspec">svg/list-search.svg|${window-title-icon-size}|||${window-title-icon-stroke}</attribute>
					</file>
					<file name="tree">
						<attribute name="iconspec">svg/list-tree.svg|${window-title-icon-size}|||${window-title-icon-stroke}</attribute>
					</file>
				</file>
			</file>

			<file name="buttons">
				<file name="camera">
					<attribute name="iconspec">svg/camera.svg|${button-size}|||${stroke-button}
					</attribute>
				</file>
			</file>
		</file>
