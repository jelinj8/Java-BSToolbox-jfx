		<file name="ui">
			<file name="help" />
			<file name="themes">
				<file name="light">
					<!-- light-theme iconspec variable overrides — finetuned later -->
					<attribute name="stroke-button" value="868e96" />
					<attribute name="window-title-icon-stroke" value="868e96" />
				</file>
				<file name="dark">
					<!-- dark-theme iconspec variable overrides — finetuned later -->
					<attribute name="stroke-add" value="40c057" />
					<attribute name="stroke-remove" value="ff6b6b" />
					<attribute name="stroke-delete" value="ff6b6b" />
					<attribute name="stroke-edit" value="74c0fc" />
					<attribute name="stroke-info" value="74c0fc" />
					<attribute name="stroke-warning" value="ffa94d" />
					<attribute name="stroke-error" value="ff6b6b" />
					<attribute name="stroke-button" value="dee2e6" />
					<attribute name="window-title-icon-stroke" value="dee2e6" />
				</file>
			</file>
		</file>
	</file>
